    {
      "label": "Requirement: 30x30 maze, 16 per cell, one entry + one exit",
      "file_type": "rationale",
      "source_file": "AI gen.txt",
      "source_location": "L3",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Fixed 30x30 grid with a single entrance and single exit defines the playfield scope. Spec says 16 cm per cell; the code interprets this as 16 px per cell (unit discrepancy).",
      "id": "aigen_maze_30x30",
      "community": 3,
      "norm_label": "requirement: 30x30 maze, 16 per cell, one entry + one exit"
    },
    {
      "label": "Requirement: entry/exit mutually reachable, >=5 computations",
      "file_type": "rationale",
      "source_file": "AI gen.txt",
      "source_location": "L4",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Spec demands the two points be provably connected and that at least 5 'computations' occur when placing them. Code satisfies this by BFS-ing >=5 random border pairs and keeping the pair with the longest shortest path, which both proves connectivity and maximizes challenge.",
      "id": "aigen_entry_exit_connectivity",
      "community": 0,
      "norm_label": "requirement: entry/exit mutually reachable, >=5 computations"
    },
    {
      "label": "Requirement: mouse player sprite <=16x16, moves 1 cell per press",
      "file_type": "rationale",
      "source_file": "AI gen.txt",
      "source_location": "L5",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Player is a mouse no larger than one cell (spec says 16x16 cm, code uses 16x16 px), stepping exactly one cell per key press so movement stays grid-aligned.",
      "id": "aigen_mouse_player_16px",
      "community": 5,
      "norm_label": "requirement: mouse player sprite <=16x16, moves 1 cell per press"
    },
    {
      "label": "Requirement: 3-minute limit -> GAME OVER + restart",
      "file_type": "rationale",
      "source_file": "AI gen.txt",
      "source_location": "L5",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Walking for more than 3 minutes triggers a game over screen followed by an automatic restart, keeping rounds short.",
      "id": "aigen_time_limit_3min",
      "community": 1,
      "norm_label": "requirement: 3-minute limit -> game over + restart"
    },
    {
      "label": "Requirement: cheese at finish, shortest path shown as scent light",
      "file_type": "rationale",
      "source_file": "AI gen.txt",
      "source_location": "L6",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "The mouse always 'knows' its shortest path to the cheese, visualized as a light resembling cheese smell. The code approximates this with a straight glowing beacon line from mouse to cheese rather than rendering the actual BFS path cells \u2014 a simplification of the spec's intent.",
